# Environment and secrets
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Output (regenerated on every run)
output/
logs/

# Datasets: ignore everything in datasets/ except the public benchmark dataset.
# (datasets/* rather than datasets/ so a single file can be re-included; the
# negation must come after the *.csv rule below, since last match wins.)
datasets/*
*.csv
*.xlsx
*.parquet
!datasets/.gitkeep
!datasets/f1_driver_vs_car.csv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
# Verification runs and the last-run pointer (regenerated; see --verify)
output_verify/
.delve_last_run
# Eval harness: generated data and run results are never committed.
# Tracked: eval/*.py, eval/DESIGN.md, and the frozen seed banks
# (eval/seeds_f1.json, eval/seeds_planted.json). The synthetic dataset and
# its answer key are regenerated deterministically (eval/planted_dgp.py,
# fixed --seed), so the generator seed IS the freeze — committing the data
# adds nothing and risks truth.json travelling with the CSV.
eval/planted/
eval/results*/
/results*.zip