# Environment and secrets
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Output (regenerated on every run)
output/
logs/

# Datasets: ignore everything in datasets/ except the public benchmark dataset.
# (datasets/* rather than datasets/ so a single file can be re-included; the
# negation must come after the *.csv rule below, since last match wins.)
datasets/*
*.csv
*.xlsx
*.parquet
!datasets/.gitkeep
!datasets/f1_driver_vs_car.csv

# Tests (kept locally, not published to GitHub)
tests/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
# Verification runs and the last-run pointer (regenerated; see --verify)
output_verify/
.delve_last_run