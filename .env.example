# Set keys for the providers you use. Leave blank for providers you don't need.

# Anthropic (default) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter — https://openrouter.ai/settings/keys
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama — https://ollama.com/. Inference needs no API key (cloud models route
# through your local Ollama installation). OLLAMA_API_KEY enables web search for
# an ollama-seated run: it is free on any ollama account (rate-limited, never
# billed), and an ollama Investigator prefers it over the paid search seats, so an
# all-ollama run stays free. Create a key at https://ollama.com/settings/keys.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
