# Set keys for the providers you use. Leave blank for providers you don't need.

# Anthropic (default) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter — https://openrouter.ai/settings/keys
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama — https://ollama.com/. Does not require an API key as cloud models route through your local Ollama installation.
OLLAMA_BASE_URL=http://localhost:11434
